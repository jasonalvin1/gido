<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 지문/생체 인증 권한 -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <!-- 지문 하드웨어 없는 기기도 설치 가능하도록 required=false -->
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />

    <!-- 전화 걸기 -->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- CALL_PHONE이 전화 기능을 자동 필수 요건으로 만들기 때문에, WiFi 전용 태블릿도 설치 가능하도록 required=false -->
    <uses-feature android:name="android.hardware.telephony" android:required="false" />

    <!-- 파일 저장 권한 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>

    <!-- 알림 권한 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- 정확한 알람 예약 (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.USE_EXACT_ALARM"/>

    <!-- 배터리 최적화 제외 요청 (Samsung 등 알람 미발송 방지) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <!-- 부팅 후 알람 복구 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- 진동 -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- 음성 입력 (speech_to_text) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <!-- 마이크 하드웨어 없는 기기도 설치 가능 -->
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- url_launcher 쿼리 -->
    <queries>
        <intent>
            <action android:name="android.intent.action.DIAL" />
            <data android:scheme="tel" />
        </intent>
        <!-- 음성 인식 서비스 쿼리 (Android 11+) -->
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:label="기억 도우미"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- .gido 파일 열기: 가능한 모든 경우 대응 -->
            <!-- 1. file:// URI -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="file" android:mimeType="*/*" />
            </intent-filter>
            <!-- 2. content:// + application/octet-stream (카카오톡 주로 사용) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content"
                      android:mimeType="application/octet-stream" />
            </intent-filter>
            <!-- 3. content:// + 모든 MIME 타입 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="*/*" />
            </intent-filter>
            <!-- 4. content:// MIME 타입 없음 (null mime type 케이스) -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
            </intent-filter>
            <!-- 5. application/octet-stream 범용 -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- flutter_local_notifications: 예약 알람 수신 -->
        <receiver
            android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver" />

        <!-- flutter_local_notifications: 부팅 후 알람 복구 -->
        <receiver
            android:exported="false"
            android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>
